## Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres

## Ports
BACKEND_PORT=8000
FRONTEND_PORT=3003
# REDIS_PORT=6379

## Redis (uncomment to enable ARQ worker for background runs)
## For local dev:  REDIS_URL=redis://localhost:6379
## For Docker:     REDIS_URL=redis://redis:6379
## Then run: docker compose --profile redis up --build
# REDIS_URL=redis://localhost:6379

## LLM
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# MODEL=anthropic/claude-sonnet-4-5-20250929

## LangSmith (optional — set to enable tracing)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=langgraph-fastapi-boilerplate
